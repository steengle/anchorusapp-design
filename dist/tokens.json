{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$comment": "Brand v2 token catalog. Mirrors dist/tokens.css. See family-hub-app/docs/BRAND_V2.md for the canonical specification.",
    "version": "1.0.2",
    "color": {
        "sage": {
            "50":  "#f3f5f1",
            "100": "#e6ebe4",
            "200": "#c9d3c5",
            "400": "#869681",
            "500": "#5a6b5a",
            "600": "#4a594a",
            "700": "#3b4a3b",
            "900": "#1f2a1f"
        },
        "gold": {
            "100": "#f0e8d0",
            "500": "#8b7340",
            "700": "#6b5730"
        },
        "copper": {
            "dk": "#7a3f24",
            "lt": "#eab393"
        },
        "surface": {
            "linen":       "#fffdf8",
            "linen-inset": "#faf6ef",
            "linen-shade": "#f7f2ea",
            "paper":       "#ffffff"
        },
        "ink": {
            "default": "#3d3830",
            "label":   "#4a4238",
            "subtle":  "#6b6055",
            "muted":   "#8a8078",
            "dim":     "#9a8f80"
        },
        "divider": {
            "default": "#bfb299",
            "soft":    "#dbd0ba"
        },
        "semantic": {
            "success":      "#4b823c",
            "warning":      "#a07d1a",
            "danger":       "#b43c3c",
            "danger-hover": "#9a3333",
            "info":         "#2d64a0"
        },
        "chart": {
            "pink":  "#b43c6e",
            "teal":  "#2a8a8a",
            "grape": "#7a5c99"
        }
    },
    "typography": {
        "family": {
            "serif-display": "'Fraunces', 'Playfair Display', Georgia, serif",
            "serif":         "'Playfair Display', Georgia, serif",
            "sans":          "'Karla', 'Segoe UI', system-ui, sans-serif",
            "mono":          "'IBM Plex Mono', monospace"
        },
        "scale": {
            "display-lg":   { "size": 40, "leading": 48, "weight": 350, "family": "serif-display" },
            "display":      { "size": 32, "leading": 40, "weight": 400, "family": "serif-display" },
            "display-sm":   { "size": 24, "leading": 32, "weight": 400, "family": "serif-display" },
            "title":        { "size": 22, "leading": 30, "weight": 400, "family": "serif" },
            "subtitle":     { "size": 17, "leading": 24, "weight": 500, "family": "sans" },
            "body":         { "size": 16, "leading": 26, "weight": 400, "family": "sans" },
            "body-sm":      { "size": 14, "leading": 22, "weight": 400, "family": "sans" },
            "caption":      { "size": 12, "leading": 18, "weight": 500, "family": "sans" },
            "eyebrow":      { "size": 11, "leading": 14, "weight": 600, "family": "sans", "uppercase": true, "tracking": 0.08 }
        }
    },
    "radius": {
        "2xs":  3,
        "xs":   6,
        "sm":  10,
        "default": 16,
        "lg":  20,
        "pill": 999
    },
    "spacing": {
        "1":  4,
        "2":  8,
        "3": 12,
        "4": 16,
        "5": 24,
        "6": 32,
        "8": 48
    },
    "layout": {
        "sidebar-width": 240,
        "topbar-height": 52
    },
    "breakpoints": {
        "phone-narrow": 480,
        "phone":        600,
        "tablet":       768,
        "phone-narrow-px": "(max-width: 480px)",
        "phone-px":        "(max-width: 600px)",
        "tablet-px":       "(max-width: 768px)"
    },
    "surfaces": {
        "$comment": "Override these in consumer's local app.css to express approved divergences. Operator console (anchorusapp-control) overrides --sidebar-bg and --auth-bg to var(--sage-700).",
        "sidebar-bg":        "var(--linen-shade)",
        "sidebar-fg":        "var(--ink-muted)",
        "sidebar-fg-strong": "var(--ink)",
        "sidebar-fg-dim":    "var(--ink-dim)",
        "sidebar-border":    "var(--divider)",
        "auth-bg":           "var(--linen-inset)",
        "tab-bar-h":         "0px"
    }
}
